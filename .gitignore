# ===========================================
# Private Projects and Data
# ===========================================
**/websites/
**/content/
**/drive/MyDrive/

# ===========================================
# Python-Specific
# ===========================================
**/__pycache__/
*.py[cod]
*$py.class
**/.ipynb_checkpoints/

# ===========================================
# Virtual Environment Directories
# ===========================================
**/.env/
**/.venv/
**/venv/
**/env/

# ===========================================
# SSH / TLS Material: NEVER COMMIT
# ===========================================
*.pem
*.key
*.pfx
*.p12
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ===========================================
# IDE Files
# ===========================================
**/.vscode/
**/.idea/
**/.vs/
*.code-workspace
*.iml
*.iws
*.ipr
*.project
*.classpath
**/.csettings/
**/.settings/
**/nbproject/

# ===========================================
# Build and Distribution Directories
# ===========================================
**/dist/
**/build/
**/target/
**/bin/
**/obj/

# ===========================================
# Dependency Directories
# ===========================================
**/node_modules/

# ===========================================
# General Lock Files
# ===========================================
**/*.lock

# ===========================================
# Backup, Log, and Temporary Files
# ===========================================
**/*.log
**/*.tmp
**/*.bak
**/*.swp
*~
*.orig
*.old
*.swo
*.swp

# ===========================================
# System-Specific Files
# ===========================================
**/.DS_Store
**/.AppleDouble
**/.Trash-*
**/Thumbs.db
**/Desktop.ini
$RECYCLE.BIN/

# ===========================================
# Large and Voluminous Directories
# ===========================================
**/datasets/
**/data/
**/logs/
**/outputs/
**/generated/

# ===========================================
# Sensitive Files
# (source config like config.py / config.yaml is committed; real secrets live in .env)
# ===========================================
**/.env
**/secrets/
**/secrets.*

# ===========================================
# User-Specific Files
# ===========================================
*.user
*.suo

# Eval-harness test results (generated on demand via the Download button; never committed)
tests/results*.json
results*.json

# ===========================================
# Local-only notes / scratch: NEVER published
# Put anything I don't want on GitHub in _local/ and it stays on my disk only.
# ===========================================
_local/
# Release checker evidence generated locally or in CI
release-evidence/*.json
release-evidence/
tools/release-evidence/

/research/
